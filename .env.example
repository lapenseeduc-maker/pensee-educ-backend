# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pensee_educ

# Redis (Upstash)
REDIS_URL=redis://default:password@your-upstash-url.upstash.io:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars

# Twilio (SMS)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# Firebase FCM
FIREBASE_SERVER_KEY=AAAAxxxxxxxx:APA91bxxxxxxxxxxxxxxxxxxxx

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Orange Money
ORANGE_API_URL=https://api.orange.com
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_MERCHANT_KEY=your_merchant_key

# MTN Mobile Money
MTN_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_CLIENT_ID=your_mtn_client_id
MTN_CLIENT_SECRET=your_mtn_client_secret
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key

# App
FRONTEND_URL=https://your-app.replit.app
BACKEND_URL=https://your-backend.replit.app
PORT=3000
